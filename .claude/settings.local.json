{
  "permissions": {
    "allow": [
      "Bash(npm list:*)",
      "Bash(npm install:*)",
      "Bash(node -e \"const pkg = require\\(''@react-three/postprocessing''\\); console.log\\(Object.keys\\(pkg\\).join\\('', ''\\)\\)\")",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:cdn.jsdelivr.net)",
      "WebFetch(domain:gingerbeardman.github.io)",
      "Bash(npm run:*)",
      "Bash(grep -E \"\\\\.tsx?$\")",
      "Bash(npx tsc:*)",
      "Bash(grep -r \"devicePixelRatio\\\\|dpr\\\\|drawImage\" /z/repos/friendslop-app/src --include=*.ts --include=*.tsx)",
      "Bash(xargs grep:*)",
      "Bash(find /z/repos/friendslop-app/src -type f \\\\\\(-name *.ts -o -name *.tsx -o -name *.js -o -name *.jsx \\\\\\))",
      "Bash(xargs wc:*)",
      "Bash(grep -r export.*Cloud z:/repos/friendslop-app/node_modules/@react-three/drei/core --include=*.d.ts -l)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(node -e \"JSON.parse\\(require\\(''fs''\\).readFileSync\\(''/z/repos/friendslop-app/.claude/settings.local.json'',''utf8''\\)\\); console.log\\(''valid''\\)\")"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "(cd /z/repos/friendslop-app && npm run validate 2>&1 && npm run prettify 2>&1 && echo \"✅ All checks passed\" || echo \"❌ Checks failed (see above)\") | node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>process.stdout.write(JSON.stringify({systemMessage:d})))\"",
            "timeout": 120,
            "statusMessage": "Running validate & prettify..."
          }
        ]
      }
    ]
  }
}
